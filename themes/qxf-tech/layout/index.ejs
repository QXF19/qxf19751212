<% const profile = site.data.qxf || {}; %>
<header class="hero" id="top">
  <nav class="nav">
    <div class="logo">QXF</div>
    <a class="nav-link" href="#contact">联系</a>
  </nav>
  <div class="hero-content">
    <p class="eyebrow"><%= profile.hero?.eyebrow %></p>
    <h1><%= profile.hero?.title %></h1>
    <p class="lead"><%= profile.hero?.lead %></p>
    <div class="hero-cta">
      <% if (profile.hero?.primary_cta) { %>
      <a class="btn primary" href="<%= profile.hero.primary_cta.href %>"><%= profile.hero.primary_cta.label %></a>
      <% } %>
      <% if (profile.hero?.secondary_cta) { %>
      <a class="btn ghost" href="<%= profile.hero.secondary_cta.href %>"><%= profile.hero.secondary_cta.label %></a>
      <% } %>
    </div>
  </div>
  <div class="hero-metrics">
    <% (profile.metrics || []).forEach(metric => { %>
      <div>
        <span class="metric"><%= metric.value %></span>
        <span class="label"><%= metric.label %></span>
      </div>
    <% }) %>
  </div>
</header>

<main>
  <section class="about" id="about">
    <div class="section-heading">
      <p class="eyebrow">WHO</p>
      <h2>技术视角下的个人标签</h2>
    </div>
    <div class="about-grid">
      <% (profile.about || []).forEach(card => { %>
        <article>
          <h3><%= card.title %></h3>
          <p><%= card.text %></p>
        </article>
      <% }) %>
    </div>
  </section>

  <section class="cva">
    <div class="section-heading">
      <p class="eyebrow">CVA 组织</p>
      <h2>城市价值联盟（CVA）如何运转</h2>
    </div>
    <div class="cva-content">
      <p><%= profile.cva?.intro %></p>
      <ul>
        <% (profile.cva?.bullets || []).forEach(item => { %>
          <li><strong><%= item.title %>：</strong><%= item.text %></li>
        <% }) %>
      </ul>
    </div>
  </section>

  <section class="projects" id="projects">
    <div class="section-heading">
      <p class="eyebrow">PROJECTS</p>
      <h2>秦野科创 · 代表性实践</h2>
    </div>
    <div class="project-grid">
      <% (profile.projects || []).forEach(project => { %>
        <article>
          <h3><%= project.title %></h3>
          <p><%= project.text %></p>
          <div class="tags">
            <% (project.tags || []).forEach(tag => { %>
              <span><%= tag %></span>
            <% }) %>
          </div>
        </article>
      <% }) %>
    </div>
  </section>

  <section class="timeline">
    <div class="section-heading">
      <p class="eyebrow">TIMELINE</p>
      <h2>从构想到影响的路径</h2>
    </div>
    <ol class="timeline-list">
      <% (profile.timeline || []).forEach(node => { %>
        <li>
          <span><%= node.year %></span>
          <p><%= node.text %></p>
        </li>
      <% }) %>
    </ol>
  </section>

  <section class="contact" id="contact">
    <div class="section-heading">
      <p class="eyebrow">CONTACT</p>
      <h2>保持连线</h2>
    </div>
    <p><%= profile.contact?.text %></p>
    <div class="contact-links">
      <% (profile.contact?.links || []).forEach(link => { %>
        <a href="<%= link.href %>"><%= link.label %></a>
      <% }) %>
    </div>
  </section>
</main>

<footer class="footer">
  <p>© <span id="year"></span> 秦野科创 · CVA 组织</p>
</footer>
